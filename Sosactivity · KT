package com.safeguard.app.ui

import android.content.Intent
import android.media.AudioManager
import android.media.MediaPlayer
import android.media.RingtoneManager
import android.os.Bundle
import android.os.CountDownTimer
import android.os.VibrationEffect
import android.os.Vibrator
import android.view.View
import android.view.WindowManager
import android.widget.Toast
import androidx.activity.OnBackPressedCallback
import androidx.activity.viewModels
import androidx.appcompat.app.AppCompatActivity
import com.safeguard.app.R
import com.safeguard.app.databinding.ActivitySosBinding
import com.safeguard.app.services.SOSAlertService
import com.safeguard.app.viewmodel.SOSViewModel
import dagger.hilt.android.AndroidEntryPoint

@AndroidEntryPoint
class SOSActivity : AppCompatActivity() {

    private lateinit var binding: ActivitySosBinding
    private val viewModel: SOSViewModel by viewModels()

    private var countdownTimer: CountDownTimer? = null
    private var sirenPlayer: MediaPlayer? = null
    private var vibrator: Vibrator? = null

    // Countdown before auto-sending SOS (user can cancel)
    private val COUNTDOWN_SECONDS = 10L

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // Keep screen on and show on lock screen
        window.addFlags(
            WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON or
            WindowManager.LayoutParams.FLAG_SHOW_WHEN_LOCKED or
            WindowManager.LayoutParams.FLAG_TURN_SCREEN_ON
        )

        binding = ActivitySosBinding.inflate(layoutInflater)
        setContentView(binding.root)

        vibrator = getSystemService(VIBRATOR_SERVICE) as Vibrator

        startCountdown()
        startSiren()
        setupCancelButton()
        setupSendNowButton()
        observeViewModel()
        disableBackPress()
    }

    // ─── Countdown ───────────────────────────────────────────────────────────

    private fun startCountdown() {
        binding.tvCountdown.text = COUNTDOWN_SECONDS.toString()
        binding.countdownProgress.max = COUNTDOWN_SECONDS.toInt()

        // Vibrate pattern: on 500ms, off 300ms, repeat
        val pattern = longArrayOf(0, 500, 300)
        vibrator?.vibrate(VibrationEffect.createWaveform(pattern, 0))

        countdownTimer = object : CountDownTimer(COUNTDOWN_SECONDS * 1000, 1000) {
            override fun onTick(millisUntilFinished: Long) {
                val secondsLeft = (millisUntilFinished / 1000).toInt() + 1
                binding.tvCountdown.text = secondsLeft.toString()
                binding.countdownProgress.progress = secondsLeft
            }
            override fun onFinish() {
                binding.tvCountdown.text = "0"
                sendSOSAlert()
            }
        }.start()
    }

    // ─── Siren ───────────────────────────────────────────────────────────────

    private fun startSiren() {
        try {
            // Use loud alarm sound
            val alarmUri = RingtoneManager.getDefaultUri(RingtoneManager.TYPE_ALARM)
            sirenPlayer = MediaPlayer().apply {
                setAudioStreamType(AudioManager.STREAM_ALARM)
                setDataSource(applicationContext, alarmUri)
                isLooping = true
                prepare()
                start()
            }
            // Max volume
            val am = getSystemService(AUDIO_SERVICE) as AudioManager
            am.setStreamVolume(
                AudioManager.STREAM_ALARM,
                am.getStreamMaxVolume(AudioManager.STREAM_ALARM),
                0
            )
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    private fun stopSiren() {
        sirenPlayer?.stop()
        sirenPlayer?.release()
        sirenPlayer = null
    }

    // ─── Buttons ─────────────────────────────────────────────────────────────

    private fun setupCancelButton() {
        binding.btnCancelSOS.setOnClickListener {
            cancelSOS()
        }
    }

    private fun setupSendNowButton() {
        binding.btnSendNow.setOnClickListener {
            countdownTimer?.cancel()
            sendSOSAlert()
        }
    }

    private fun cancelSOS() {
        countdownTimer?.cancel()
        stopSiren()
        vibrator?.cancel()
        binding.layoutCountdown.visibility = View.GONE
        binding.layoutCancelled.visibility = View.VISIBLE
        // Return to home after 2 seconds
        binding.root.postDelayed({ finish() }, 2000)
    }

    // ─── SOS Alert ───────────────────────────────────────────────────────────

    private fun sendSOSAlert() {
        binding.layoutCountdown.visibility = View.GONE
        binding.layoutSending.visibility = View.VISIBLE
        binding.tvSendingStatus.text = getString(R.string.sending_sos)

        // Start foreground SOS service (sends SMS, shares location, calls)
        val sosIntent = Intent(this, SOSAlertService::class.java)
        startForegroundService(sosIntent)

        viewModel.triggerSOS()
    }

    // ─── Observe ─────────────────────────────────────────────────────────────

    private fun observeViewModel() {
        viewModel.sosSentStatus.observe(this) { status ->
            when (status) {
                SOSViewModel.SOSStatus.SENDING -> {
                    binding.tvSendingStatus.text = getString(R.string.sending_sos)
                }
                SOSViewModel.SOSStatus.SUCCESS -> {
                    stopSiren()
                    vibrator?.cancel()
                    binding.tvSendingStatus.text = getString(R.string.sos_sent_successfully)
                    binding.lottieSent.visibility = View.VISIBLE
                    binding.lottieSent.playAnimation()
                    binding.tvContactsNotified.text = viewModel.getNotifiedContactsSummary()
                    binding.layoutContactsNotified.visibility = View.VISIBLE
                }
                SOSViewModel.SOSStatus.PARTIAL -> {
                    binding.tvSendingStatus.text = getString(R.string.sos_partial_success)
                    Toast.makeText(this, viewModel.errorMessage, Toast.LENGTH_LONG).show()
                }
                SOSViewModel.SOSStatus.FAILED -> {
                    binding.tvSendingStatus.text = getString(R.string.sos_failed)
                    Toast.makeText(this, viewModel.errorMessage, Toast.LENGTH_LONG).show()
                }
                else -> {}
            }
        }

        viewModel.currentLocation.observe(this) { location ->
            if (location != null) {
                binding.tvLocationSharing.text = "📍 Location: ${location.latitude}, ${location.longitude}"
                binding.tvLocationSharing.visibility = View.VISIBLE
            }
        }
    }

    // ─── Back Press ──────────────────────────────────────────────────────────

    private fun disableBackPress() {
        onBackPressedDispatcher.addCallback(this, object : OnBackPressedCallback(true) {
            override fun handleOnBackPressed() {
                // Block back press during SOS — user must explicitly cancel
                Toast.makeText(
                    this@SOSActivity,
                    "Press Cancel to dismiss SOS",
                    Toast.LENGTH_SHORT
                ).show()
            }
        })
    }

    override fun onDestroy() {
        super.onDestroy()
        countdownTimer?.cancel()
        stopSiren()
        vibrator?.cancel()
    }
}
